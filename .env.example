# OpenRouter API Key for LLM scoring
OPENROUTER_API_KEY=your_key_here

# Optional: Override default LLM model
# LLM_MODEL=google/gemini-3-flash-preview

# Optional: Override default LLM temperature
# LLM_TEMPERATURE=0.2

# Optional: Override default delay between LLM requests (seconds)
# LLM_DELAY=0.5

# Optional: Override default scrape delay (seconds)
# SCRAPE_DELAY=1.0

# Optional: Override default request timeout (milliseconds)
# REQUEST_TIMEOUT=15000
